# Coursera OAuth 2.0 app credentials (required only for enrolled-content tools)
# Apply for Coursera partner/developer program to obtain these:
# https://partner.coursera.help/hc/en-us/articles/209819543
COURSERA_CLIENT_ID=
COURSERA_CLIENT_SECRET=

# Optional: a static secret key to protect your MCP endpoint from anonymous access
# Leave empty to allow unauthenticated access to public tools
CONNECTOR_SECRET_KEY=
